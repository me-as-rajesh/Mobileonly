{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public and private profile data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatar": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["buyer", "seller", "both"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt", "updatedAt"]
    },
     "Listing": {
      "title": "Listing",
      "description": "Represents a marketplace listing for a used smartphone.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the listing generated by Firebase." },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "variant": {
          "type": "object",
          "properties": {
            "ram": { "type": "number" },
            "storage": { "type": "number" }
          }
        },
        "condition": { "type": "string", "enum": ["new", "like_new", "good", "fair"] },
        "purchaseYear": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "state": { "type": "string" },
            "district": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "seller": { "type": "string", "description": "The UID of the seller user." },
        "status": { "type": "string", "enum": ["active", "sold", "flagged"], "default": "active" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "price", "brand", "model", "variant", "condition", "location", "images", "seller"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Metadata for a chat conversation between a buyer and a seller about a listing.",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessageText": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "listingTitle": { "type": "string" },
        "listingPrice": { "type": "number" },
        "listingImage": { "type": "string", "format": "uri" },
        "buyerName": { "type": "string" },
        "buyerAvatar": { "type": "string", "format": "uri" },
        "sellerName": { "type": "string" },
        "sellerAvatar": { "type": "string", "format": "uri" }
      },
       "required": ["listingId", "buyerId", "sellerId", "participants", "lastMessageAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual chat message within a conversation.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["senderId", "text", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "realtimeDatabase": {
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile data, keyed by Firebase Auth UID."
    },
    "/listings/{listingId}": {
      "schema": { "$ref": "#/entities/Listing" },
      "description": "Stores all marketplace listings, keyed by a unique push ID."
    },
    "/user-listings/{uid}/{listingId}": {
      "schema": { "type": "boolean" },
      "description": "An index to quickly find all listings created by a specific user."
    }
  },
  "firestore": {
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Stores metadata for each conversation."
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores all messages for a specific conversation."
    }
  }
}
